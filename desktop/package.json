{
  "name": "factor-lab-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for the Factor Lab frontend.",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:frontend": "node -e \"console.log('Factor Lab frontend is static; no frontend build step is required.')\"",
    "build": "npm run build:frontend && electron-builder --win nsis portable",
    "build:win": "npm run build",
    "pack:win": "electron-builder --win --dir",
    "build:mac": "npm run build:frontend && electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.agentmatrix.factorlab",
    "productName": "Factor Lab",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/factor-lab-dashboard",
        "to": "frontend/factor-lab-dashboard",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.finance"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
